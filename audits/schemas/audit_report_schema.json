{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Audit Report Schema",
  "type": "object",
  "required": ["auditType", "status", "startedAt", "completedAt", "durationMs", "summary", "checks"],
  "properties": {
    "auditType": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["pass", "warn", "fail", "critical"]
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    },
    "durationMs": {
      "type": "integer",
      "minimum": 0
    },
    "summary": {
      "type": "object",
      "required": ["pass", "warn", "fail", "critical"],
      "properties": {
        "pass": { "type": "integer", "minimum": 0 },
        "warn": { "type": "integer", "minimum": 0 },
        "fail": { "type": "integer", "minimum": 0 },
        "critical": { "type": "integer", "minimum": 0 }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pass", "warn", "fail", "critical"]
          },
          "details": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["pass", "warn", "fail", "critical"]
          },
          "durationMs": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "metrics": {
      "type": "object"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "stack": { "type": "string" },
          "at": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}