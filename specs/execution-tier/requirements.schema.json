{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emperor-os.local/specs/execution-tier/requirements.schema.json",
  "type": "object",
  "required": ["specVersion", "source", "requirements", "acceptanceTests"],
  "properties": {
    "specVersion": { "type": "string" },
    "source": {
      "type": "object",
      "required": ["path", "versionDate"],
      "properties": {
        "path": { "type": "string" },
        "versionDate": { "type": "string" }
      },
      "additionalProperties": false
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "category", "normativeLevel", "statement", "machineCheck", "acceptanceTestId"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z]{2}-\\d{3}$" },
          "category": { "type": "string" },
          "normativeLevel": { "type": "string" },
          "statement": { "type": "string", "minLength": 1 },
          "machineCheck": { "type": "object" },
          "acceptanceTestId": { "type": "string", "pattern": "^AT-[A-Z]{2}-\\d{3}$" }
        },
        "additionalProperties": false
      }
    },
    "acceptanceTests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "coversRequirementId", "description", "type"],
        "properties": {
          "id": { "type": "string", "pattern": "^AT-[A-Z]{2}-\\d{3}$" },
          "coversRequirementId": { "type": "string", "pattern": "^[A-Z]{2}-\\d{3}$" },
          "description": { "type": "string", "minLength": 1 },
          "type": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
