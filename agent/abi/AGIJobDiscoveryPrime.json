[
  {
    "type": "function",
    "name": "commitApplication",
    "inputs": [
      { "name": "procurementId", "type": "uint256" },
      { "name": "commitment", "type": "bytes32" },
      { "name": "subdomain", "type": "string" },
      { "name": "proof", "type": "bytes32[]" }
    ],
    "outputs": [],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "revealApplication",
    "inputs": [
      { "name": "procurementId", "type": "uint256" },
      { "name": "subdomain", "type": "string" },
      { "name": "proof", "type": "bytes32[]" },
      { "name": "salt", "type": "bytes32" },
      { "name": "applicationURI", "type": "string" }
    ],
    "outputs": [],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "acceptFinalist",
    "inputs": [
      { "name": "procurementId", "type": "uint256" }
    ],
    "outputs": [],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "submitTrial",
    "inputs": [
      { "name": "procurementId", "type": "uint256" },
      { "name": "trialURI", "type": "string" }
    ],
    "outputs": [],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "procurements",
    "inputs": [
      { "name": "procurementId", "type": "uint256" }
    ],
    "outputs": [
      { "name": "jobId", "type": "uint256" },
      { "name": "employer", "type": "address" },
      { "name": "commitDeadline", "type": "uint256" },
      { "name": "revealDeadline", "type": "uint256" },
      { "name": "finalistAcceptDeadline", "type": "uint256" },
      { "name": "trialDeadline", "type": "uint256" },
      { "name": "scoreCommitDeadline", "type": "uint256" },
      { "name": "scoreRevealDeadline", "type": "uint256" }
    ],
    "stateMutability": "view"
  },
  {
    "type": "function",
    "name": "applicationView",
    "inputs": [
      { "name": "procurementId", "type": "uint256" },
      { "name": "agent", "type": "address" }
    ],
    "outputs": [
      { "name": "phase", "type": "uint8" },
      { "name": "applicationURI", "type": "string" },
      { "name": "commitment", "type": "bytes32" },
      { "name": "shortlisted", "type": "bool" }
    ],
    "stateMutability": "view"
  },
  {
    "type": "event",
    "name": "ProcurementCreated",
    "inputs": [
      { "name": "procurementId", "type": "uint256", "indexed": true },
      { "name": "jobId", "type": "uint256", "indexed": true },
      { "name": "employer", "type": "address", "indexed": true }
    ]
  },
  {
    "type": "event",
    "name": "ShortlistFinalized",
    "inputs": [
      { "name": "procurementId", "type": "uint256", "indexed": true },
      { "name": "finalists", "type": "address[]", "indexed": false }
    ]
  }
]
